---
const primarySkills = new Set([
  "React", "Next.js", "Tailwind CSS", "JavaScript",
  "n8n", "Zapier", "Make", "OpenAI API",
]);

const skillGroups = [
  {
    label: "Frontend",
    skills: ["React", "Next.js", "Tailwind CSS", "JavaScript", "TypeScript", "Vue.js", "HTML / CSS"],
  },
  {
    label: "Backend & DB",
    skills: ["Node.js", "Supabase", "Firebase", "PostgreSQL"],
  },
  {
    label: "Automation & AI",
    skills: ["n8n", "Zapier", "Make", "OpenAI API", "AI Chatbots", "Prompt Engineering"],
  },
  {
    label: "Tooling",
    skills: ["Figma", "Git"],
  },
];
---

<section id="skills">
  <div class="container">
    <h2 class="section-label reveal">Skills</h2>
    <div class="skills-groups reveal reveal-delay-1">
      {
        skillGroups.map((group) => (
          <div class="skill-group">
            <div class="skill-group-label">{group.label}</div>
            <div class="skills-wrap">
              {group.skills.map((s) => (
                <span class={`skill-pill${primarySkills.has(s) ? " primary" : ""}`}>{s}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
