---
interface Feature { text: string; included?: boolean }
interface Props {
  tier: string;
  name: string;
  desc: string;
  currency?: string;
  amount: string;
  period?: string;
  note?: string;
  features: Feature[];
  cta: string;
  ctaStyle?: 'primary' | 'accent' | 'outline';
  featured?: boolean;
  badge?: string;
  delay?: number;
}
const {
  tier, name, desc,
  currency = '$', amount, period,
  note, features,
  cta, ctaStyle = 'outline',
  featured = false, badge,
  delay = 1,
} = Astro.props;
---
<div class={`price-card reveal reveal-delay-${delay}${featured ? ' featured' : ''}`}>
  {badge && <div class="price-badge">{badge}</div>}
  <div class="price-tier">{tier}</div>
  <div class="price-name">{name}</div>
  <div class="price-desc">{desc}</div>
  <div class="price-amount">
    <span class="currency">{currency}</span>
    <span class="amount">{amount}</span>
    {period && <span class="period">{period}</span>}
  </div>
  {note && <div class="price-note">{note}</div>}
  <div class="price-divider"></div>
  <div class="price-features">
    {features.map(f => (
      <div class={`price-feature${f.included === false ? ' dim' : ''}`}>
        {f.included === false
          ? <div class="pf-x">✕</div>
          : (
            <div class="pf-check">
              <svg viewBox="0 0 10 10" fill="none">
                <path d="M2 5l2.5 2.5L8 3" stroke="#3aba78" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
          )
        }
        <span>{f.text}</span>
      </div>
    ))}
  </div>
  <a class={`price-cta ${ctaStyle}`} href="#contact">{cta}</a>
</div>
