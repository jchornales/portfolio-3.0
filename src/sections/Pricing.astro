---
import { webTiers, automationTiers } from "../constants/pricing";
---

<section id="pricing">
  <div class="container">
    <div class="section-label reveal">Pricing</div>

    <div class="pricing-tabs reveal reveal-delay-1" role="tablist" aria-label="Pricing categories">
      <button
        class="pricing-tab-btn active"
        role="tab"
        data-tab="web"
        aria-selected="true"
        aria-controls="tab-panel-web"
        id="tab-btn-web"
      >
        Web Development
      </button>
      <button
        class="pricing-tab-btn"
        role="tab"
        data-tab="automation"
        aria-selected="false"
        aria-controls="tab-panel-automation"
        id="tab-btn-automation"
        tabindex="-1"
      >
        Automation
      </button>
    </div>

    <!-- Web Development panel -->
    <div
      class="pricing-tab-panel active"
      id="tab-panel-web"
      role="tabpanel"
      aria-labelledby="tab-btn-web"
    >
      <div class="pricing-grid">
        {
          webTiers.map((t) => (
            <div class={`price-card${t.featured ? " featured" : ""} reveal reveal-delay-${t.delay}`}>
              {t.featured && <div class="price-badge">Most Popular</div>}
              <div class="price-tier">{t.tier}</div>
              <div class="price-name">{t.name}</div>
              <div class="price-desc">{t.desc}</div>
              <div class="price-amount">
                <div class="price-amount-row">
                  <span class="price-currency">{t.currency}</span>
                  <span class="price-num">{t.amount}</span>
                  {t.originalAmount && (
                    <span class="price-was">{t.currency}{t.originalAmount}</span>
                  )}
                </div>
              </div>
              <div class="price-period">{t.period}</div>
              <div class="price-note">{t.note}</div>
              <div class="price-divider" />
              <div class="price-features">
                {t.features.map((f) => (
                  <div class={`price-feature${f.dim ? " dim" : ""}`}>
                    <div class="pf-dot" />
                    {f.label}
                  </div>
                ))}
              </div>
              <a class="price-cta-btn" href="#contact">
                {t.cta}
              </a>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Automation panel -->
    <div
      class="pricing-tab-panel"
      id="tab-panel-automation"
      role="tabpanel"
      aria-labelledby="tab-btn-automation"
      hidden
    >
      <div class="pricing-grid automation-grid">
        {
          automationTiers.map((t) => (
            <div class={`price-card${t.featured ? " featured" : ""} reveal reveal-delay-${t.delay}`}>
              {t.featured && <div class="price-badge">Most Popular</div>}
              <div class="price-tier">{t.tier}</div>
              <div class="price-name">{t.name}</div>
              <div class="price-desc">{t.desc}</div>
              <div class="price-amount">
                <div class="price-amount-row">
                  <span class="price-currency">{t.currency}</span>
                  <span class="price-num">{t.amount}</span>
                  {t.originalAmount && (
                    <span class="price-was">{t.currency}{t.originalAmount}</span>
                  )}
                </div>
              </div>
              <div class="price-period">{t.period}</div>
              <div class="price-note">{t.note}</div>
              <div class="price-divider" />
              <div class="price-features">
                {t.features.map((f) => (
                  <div class={`price-feature${f.dim ? " dim" : ""}`}>
                    <div class="pf-dot" />
                    {f.label}
                  </div>
                ))}
              </div>
              <a class="price-cta-btn" href="#contact">
                {t.cta}
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".pricing-tab-btn");
  const panels = document.querySelectorAll<HTMLElement>(".pricing-tab-panel");

  function activateTab(btn: HTMLButtonElement) {
    const target = btn.dataset.tab;

    tabs.forEach((t) => {
      const isActive = t.dataset.tab === target;
      t.classList.toggle("active", isActive);
      t.setAttribute("aria-selected", String(isActive));
      t.setAttribute("tabindex", isActive ? "0" : "-1");
    });

    panels.forEach((p) => {
      const isActive = p.id === `tab-panel-${target}`;
      p.classList.toggle("active", isActive);
      if (isActive) {
        p.removeAttribute("hidden");
      } else {
        p.setAttribute("hidden", "");
      }
    });
  }

  tabs.forEach((btn) => {
    btn.addEventListener("click", () => activateTab(btn));

    btn.addEventListener("keydown", (e) => {
      const list = [...tabs];
      const idx = list.indexOf(btn);
      if (e.key === "ArrowRight" || e.key === "ArrowDown") {
        e.preventDefault();
        const next = list[(idx + 1) % list.length];
        next.focus();
        activateTab(next);
      }
      if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
        e.preventDefault();
        const prev = list[(idx - 1 + list.length) % list.length];
        prev.focus();
        activateTab(prev);
      }
    });
  });
</script>
