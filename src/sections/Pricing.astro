---
const tiers = [
  {
    tier: "Starter",
    name: "Landing Page",
    desc: "A fast, professional online presence for businesses getting started.",
    currency: "$",
    amount: "299",
    period: "/ project",
    note: "One-time · Delivered in 5–7 days",
    features: [
      { label: "Up to 5 sections", dim: false },
      { label: "Mobile responsive", dim: false },
      { label: "Contact form", dim: false },
      { label: "Basic SEO setup", dim: false },
      { label: "CMS / blog", dim: true },
      { label: "Backend / database", dim: true },
    ],
    cta: "Get a Quote",
    featured: false,
    delay: 1,
  },
  {
    tier: "Growth",
    name: "Full Website",
    desc: "Multi-page site with CMS and custom design for growing businesses.",
    currency: "$",
    amount: "799",
    period: "/ project",
    note: "One-time · Delivered in 2–3 weeks",
    features: [
      { label: "Up to 10 pages", dim: false },
      { label: "Mobile responsive", dim: false },
      { label: "CMS integration", dim: false },
      { label: "Blog / portfolio", dim: false },
      { label: "Custom animations", dim: false },
      { label: "SEO + analytics", dim: false },
    ],
    cta: "Get a Quote",
    featured: true,
    delay: 2,
  },
  {
    tier: "Custom",
    name: "Web App",
    desc: "Full-stack application with database, auth, dashboards, and custom logic.",
    currency: "$",
    amount: "1,500",
    period: "+ / project",
    note: "Custom quote · Timeline by scope",
    features: [
      { label: "React / Next.js full-stack", dim: false },
      { label: "Database & auth (Supabase)", dim: false },
      { label: "Admin dashboard", dim: false },
      { label: "API integrations", dim: false },
      { label: "Deployment & hosting", dim: false },
      { label: "30-day support", dim: false },
    ],
    cta: "Let's Talk",
    featured: false,
    delay: 3,
  },
];
---

<section id="pricing">
  <div class="container">
    <div class="section-label reveal">Pricing</div>
    <div class="pricing-grid">
      {
        tiers.map((t) => (
          <div class={`price-card${t.featured ? " featured" : ""} reveal reveal-delay-${t.delay}`}>
            {t.featured && <div class="price-badge">Most Popular</div>}
            <div class="price-tier">{t.tier}</div>
            <div class="price-name">{t.name}</div>
            <div class="price-desc">{t.desc}</div>
            <div class="price-amount">
              <span class="price-currency">{t.currency}</span>
              <span class="price-num">{t.amount}</span>
            </div>
            <div class="price-period">{t.period}</div>
            <div class="price-note">{t.note}</div>
            <div class="price-divider" />
            <div class="price-features">
              {t.features.map((f) => (
                <div class={`price-feature${f.dim ? " dim" : ""}`}>
                  <div class="pf-dot" />
                  {f.label}
                </div>
              ))}
            </div>
            <a class="price-cta-btn" href="#contact">
              {t.cta}
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
