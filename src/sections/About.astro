---
const chips = ["Philippines", "Open to remote", "3+ years exp.", "Fast turnaround"];
---

<section id="about">
  <div class="container">
    <div class="section-label reveal">About</div>
    <div class="about-inner">
      <div>
        <h2 class="about-h2 reveal reveal-delay-1">
          Frontend-first.<br />Architecture-focused.<br />Automation-driven.
        </h2>
      </div>
      <div class="about-body reveal reveal-delay-2">
        <p>
          Frontend developer since September 2021, now expanding into full-stack with AI assistance.
          I focus on <strong>software architecture</strong> — thinking about how systems connect and scale,
          not just writing features.
        </p>
        <p>
          I help businesses ship faster by pairing clean web development with automation pipelines
          and AI integrations that eliminate manual work.
        </p>
        <p>
          Looking for <strong>freelance</strong>, <strong>part-time</strong>, or <strong
            >full-time</strong
          >
          opportunities — remote-friendly.
        </p>
        <div class="about-chips">
          {chips.map((c) => <span class="chip">{c}</span>)}
        </div>
      </div>
    </div>
  </div>
</section>
