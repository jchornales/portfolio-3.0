---
const chips = [
  '📍 Philippines',
  '🌏 Open to remote',
  '⚡ Fast turnaround',
  '🏗️ Architecture-first',
  '🤖 AI-assisted full-stack',
];
---
<section id="about" class="section section-alt">
  <div class="container">
    <div class="about-grid">
      <div class="about-photo reveal">
        <div class="about-photo-inner"></div>
        <span class="about-photo-label">Profile photo</span>
      </div>
      <div class="about-text">
        <div class="eyebrow reveal">About Me</div>
        <h2 class="section-title reveal reveal-delay-1">The human behind the builds</h2>
        <div class="reveal reveal-delay-2">
          <p>
            Frontend developer since September 2021, now expanding into full-stack
            with AI assistance. I focus on <strong>software architecture</strong> —
            thinking about how systems connect and scale, not just writing features.
          </p>
          <p>
            I help businesses ship faster by pairing clean web development with
            automation pipelines and AI integrations that eliminate manual work and
            unlock growth.
          </p>
          <p>
            Looking for <strong>freelance</strong> and <strong>part-time</strong>
            opportunities — remote-friendly.
          </p>
          <div class="about-chips">
            {chips.map(c => <span class="chip">{c}</span>)}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
