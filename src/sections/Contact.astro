---
import ContactForm from "../components/ContactForm.tsx";
---

<section id="contact">
  <div class="container">
    <div class="section-label reveal">Get in Touch</div>
    <div class="contact-inner">
      <div class="contact-left reveal reveal-delay-1">
        <h2 class="contact-tagline">
          Let's build<br />something<br /><em>great.</em>
        </h2>
        <p class="contact-meta">
          Tell me what you're working on. Website, automation, or something custom — I respond
          within 24 hours and we'll figure out if it's a good fit.
        </p>
        <a class="contact-email-link" href="mailto:jchornales.dev@gmail.com">
          jchornales.dev@gmail.com
        </a>
      </div>
      <div class="reveal reveal-delay-2">
        <ContactForm client:visible />
      </div>
    </div>
  </div>
</section>
