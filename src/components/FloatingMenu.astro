---
---
<div class="fm" id="fm" role="region" aria-label="Quick actions">

  <div class="fm-actions" id="fm-actions" aria-hidden="true">

    <!-- AI Chat (top slot — add more buttons above this line) -->
    <div class="fm-row">
      <span class="fm-tip">AI Chat</span>
      <button class="fm-btn" id="fm-chat" aria-label="Open AI Chat">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
          <path d="M13 9.5a.9.9 0 01-.9.9H4.5L2 13V3a.9.9 0 01.9-.9h9.2a.9.9 0 01.9.9v6.5z"
            stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
          <path d="M4.5 6h6M4.5 8.5h3.5"
            stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- Theme Toggle (bottom slot — closest to trigger) -->
    <div class="fm-row">
      <span class="fm-tip" id="fm-theme-tip">Dark mode</span>
      <button class="fm-btn" id="fm-theme" aria-label="Toggle dark mode">
        <!-- Moon: visible in light mode → click to go dark -->
        <svg class="fm-moon" width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
          <path d="M12.5 9A5.5 5.5 0 016 2.5a5.5 5.5 0 100 10A5.5 5.5 0 0012.5 9z"
            stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <!-- Sun: visible in dark mode → click to go light -->
        <svg class="fm-sun" width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
          <circle cx="7.5" cy="7.5" r="2.5" stroke="currentColor" stroke-width="1.4"/>
          <path d="M7.5 1.5v2M7.5 11.5v2M1.5 7.5h2M11.5 7.5h2M3.3 3.3l1.4 1.4M10.3 10.3l1.4 1.4M3.3 11.7l1.4-1.4M10.3 4.7l1.4-1.4"
            stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

  </div>

  <!-- Trigger -->
  <button class="fm-trigger" id="fm-trigger" aria-expanded="false" aria-label="Open quick actions">
    <svg class="fm-plus" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    <svg class="fm-x" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
      <path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>

</div>

<script>
  const fm       = document.getElementById('fm')!;
  const trigger  = document.getElementById('fm-trigger')!;
  const actions  = document.getElementById('fm-actions')!;
  const themeBtn = document.getElementById('fm-theme')!;
  const themeTip = document.getElementById('fm-theme-tip')!;
  const chatBtn  = document.getElementById('fm-chat')!;

  // ── Open / close ──────────────────────────────
  trigger.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = fm.classList.toggle('open');
    trigger.setAttribute('aria-expanded', String(isOpen));
    actions.setAttribute('aria-hidden', String(!isOpen));
  });

  document.addEventListener('click', (e) => {
    if (!fm.contains(e.target as Node) && fm.classList.contains('open')) {
      fm.classList.remove('open');
      trigger.setAttribute('aria-expanded', 'false');
      actions.setAttribute('aria-hidden', 'true');
    }
  });

  // ── Dark mode ─────────────────────────────────
  function applyTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
    const isDark = theme === 'dark';
    themeTip.textContent = isDark ? 'Light mode' : 'Dark mode';
    themeBtn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
  }

  themeBtn.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') ?? 'light';
    applyTheme(current === 'dark' ? 'light' : 'dark');
  });

  // ── AI Chat ───────────────────────────────────
  // Dispatches a custom event — wire up your handler with:
  // window.addEventListener('ai-chat-open', () => { ... });
  chatBtn.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('ai-chat-open'));
    fm.classList.remove('open');
    trigger.setAttribute('aria-expanded', 'false');
    actions.setAttribute('aria-hidden', 'true');
  });
</script>
