---
---
<div class="fab-stack" id="fab-stack">
  <button
    class="fab scroll-top"
    id="scroll-top-btn"
    type="button"
    aria-label="Back to top"
    title="Back to top"
  >↑</button>

  <div class="fab-menu" id="fab-menu" aria-hidden="true">
    <button
      class="fab fab-action"
      id="chatbot-btn"
      type="button"
      aria-label="Open chatbot"
      title="Chatbot"
      tabindex="-1"
    >💬</button>
    <button
      class="fab fab-action"
      id="theme-toggle-btn"
      type="button"
      aria-label="Toggle theme"
      title="Toggle theme"
      tabindex="-1"
    ><span id="theme-icon">🌙</span></button>
  </div>

  <button
    class="fab fab-toggle"
    id="fab-toggle-btn"
    type="button"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="fab-menu"
    title="Menu"
  >
    <span class="fab-toggle-icon" aria-hidden="true">+</span>
  </button>
</div>
