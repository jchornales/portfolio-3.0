---
const testimonials = [
  {
    text: '[ Add your first client testimonial here. What did Justine build? How did it help your business? Why would you recommend them? Keep it specific and honest. ]',
    initial: 'C',
    name: 'Client Name',
    role: 'CEO, Company Name',
    delay: 1,
  },
  {
    text: '[ Add a second testimonial from a different service — automation, chatbot, or another web project. Variety shows range. ]',
    initial: 'F',
    name: 'Client Name',
    role: 'Founder, Company Name',
    delay: 2,
  },
];
---
<section id="testimonials" class="section">
  <div class="container">
    <div class="eyebrow reveal">Testimonials</div>
    <h2 class="section-title reveal reveal-delay-1">What clients say</h2>
    <p class="section-sub reveal reveal-delay-2">Real words from real people. No fluff.</p>
    <div class="testi-grid">
      {testimonials.map(t => (
        <div class={`testi-card reveal reveal-delay-${t.delay}`}>
          <div class="testi-text">"{t.text}"</div>
          <div class="testi-author">
            <div class="testi-avatar">{t.initial}</div>
            <div>
              <div class="testi-name">{t.name}</div>
              <div class="testi-role">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
