---
import "../styles/global.css";
import "../styles/sections.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import FloatingMenu from "../components/FloatingMenu.astro";
import AiChat from "../components/AiChat.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Justine Hornales — Freelance Web Developer & Automation Specialist | Philippines",
  description = "Freelance web developer based in the Philippines. I build fast websites, automate workflows with n8n and Zapier, and integrate AI — available for remote projects worldwide.",
  ogImage = "/og-image.png",
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://justinehornales.dev";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": "Justine Hornales",
      "url": siteUrl,
      "image": `${siteUrl}/og-image.png`,
      "jobTitle": "Freelance Web Developer & Automation Specialist",
      "description": "Freelance web developer based in the Philippines specializing in React, Next.js, business automation with n8n and Zapier, and AI integrations.",
      "email": "jchornales.dev@gmail.com",
      "address": { "@type": "PostalAddress", "addressCountry": "PH" },
      "knowsAbout": [
        "React", "Next.js", "Tailwind CSS", "JavaScript", "TypeScript",
        "n8n", "Zapier", "Make", "OpenAI API", "Node.js",
        "Supabase", "Firebase", "PostgreSQL",
        "Business Automation", "AI Chatbot Integration", "Web Development",
      ],
      "sameAs": [],
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "Justine Hornales",
      "description": "Freelance web developer & automation specialist portfolio",
      "publisher": { "@id": `${siteUrl}/#person` },
    },
    {
      "@type": "WebPage",
      "@id": `${siteUrl}/#webpage`,
      "url": siteUrl,
      "name": "Justine Hornales — Freelance Web Developer & Automation Specialist",
      "isPartOf": { "@id": `${siteUrl}/#website` },
      "about": { "@id": `${siteUrl}/#person` },
      "description": "Portfolio of Justine Hornales — web developer and automation specialist based in the Philippines.",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
        ],
      },
    },
    {
      "@type": "ProfessionalService",
      "@id": `${siteUrl}/#service`,
      "name": "Justine Hornales — Web Development & Automation",
      "provider": { "@id": `${siteUrl}/#person` },
      "areaServed": ["PH", "Worldwide"],
      "availableChannel": {
        "@type": "ServiceChannel",
        "serviceUrl": `${siteUrl}/#contact`,
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Landing Page Development",
              "description": "Fast, professional landing pages. Delivered in 5–7 days.",
            },
            "price": "299",
            "priceCurrency": "USD",
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Full Website Development",
              "description": "Multi-page website with CMS. Delivered in 2–3 weeks.",
            },
            "price": "799",
            "priceCurrency": "USD",
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Web Application Development",
              "description": "Full-stack React/Next.js application with database and auth.",
            },
            "price": "1500",
            "priceCurrency": "USD",
          },
        ],
      },
    },
  ],
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0a0a0a" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Justine Hornales — Web Developer & Automation Specialist" />
    <meta property="og:locale" content="en_PH" />
    <meta property="og:site_name" content="Justine Hornales" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Justine Hornales — Web Developer & Automation Specialist" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Preload hero asset -->
    <link rel="preload" href="/uploads/Logo-2.1.svg" as="image" type="image/svg+xml" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" is:inline set:html={jsonLd} />

    <!-- Inline theme init: runs before paint to prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem("theme");
        const preferred = window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
        document.documentElement.setAttribute("data-theme", saved || preferred);
      })();
    </script>
  </head>
  <body>
    <Nav />
    <slot />
    <Footer />
    <FloatingMenu />
    <AiChat />

    <script>
      const mainNav = document.getElementById("main-nav");
      window.addEventListener(
        "scroll",
        () => {
          mainNav?.classList.toggle("scrolled", window.scrollY > 20);
        },
        { passive: true },
      );

      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("visible");
              revealObserver.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12 },
      );
      document.querySelectorAll(".reveal").forEach((el) => revealObserver.observe(el));
    </script>
  </body>
</html>
