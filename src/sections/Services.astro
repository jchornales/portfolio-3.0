---
const services = [
  {
    num: "01",
    name: "Web Development",
    desc: "Fast, production-ready sites built to convert",
    tags: ["React", "Next.js", "Tailwind", "Node.js"],
  },
  {
    num: "02",
    name: "Business Automation",
    desc: "Eliminate repetitive work with n8n, Zapier & Make",
    tags: ["n8n", "Zapier", "Make", "Webhooks"],
  },
  {
    num: "03",
    name: "Reservation & Scheduling",
    desc: "Booking systems that run without you in the loop",
    tags: ["Calendar Sync", "Booking Systems"],
  },
  {
    num: "04",
    name: "AI Chatbot Integration",
    desc: "Bots that qualify leads and answer questions — 24/7",
    tags: ["OpenAI", "Messenger", "Instagram"],
  },
];
---

<section id="services">
  <div class="container">
    <h2 class="section-label reveal">How I Help</h2>
    <div class="services-list">
      {
        services.map((s, i) => (
          <div class={`service-row reveal reveal-delay-${i + 1}`}>
            <span class="service-num">{s.num}</span>
            <div class="service-info">
              <span class="service-name">{s.name}</span>
              <span class="service-desc">{s.desc}</span>
            </div>
            <div class="service-tags">
              {s.tags.map((t) => (
                <span class="stag">{t}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
