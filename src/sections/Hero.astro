---
const base = import.meta.env.BASE_URL;
---

<section id="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-grid"></div>
    <img src={`${base}/uploads/Logo-2.1.svg`} class="hero-logo-bg" alt="" />
  </div>
  <div class="container">
    <div class="hero-tag reveal">
      <span class="avail-dot"></span>
      Available for freelance &amp; full-time &middot; Philippines &middot; Remote-ready
    </div>
    <h1 class="hero-h1 reveal reveal-delay-1">
      Websites that ship.<br />Workflows that <em>save hours.</em>
    </h1>
    <div class="hero-bottom">
      <div>
        <p class="hero-desc reveal reveal-delay-2">
          Frontend developer + automation builder. I deliver clean websites, n8n/Zapier pipelines,
          and AI integrations — so your team ships faster and works less manually.
        </p>
        <div class="hero-ctas reveal reveal-delay-3">
          <a href="#projects" class="btn-solid">View Work</a>
          <a href="#contact" class="btn-ghost">Start a Project &rarr;</a>
        </div>
      </div>
      <div class="hero-services reveal reveal-delay-2">
        <span class="hero-service active">Web Development</span>
        <span class="hero-service active">Workflow Automation</span>
        <span class="hero-service active">AI Integration</span>
      </div>
    </div>
  </div>
</section>
