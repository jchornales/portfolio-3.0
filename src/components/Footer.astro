---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer>
  <div class="container">
    <div class="footer-inner">
      <div class="footer-logo">
        <img src={`${base}/uploads/Logo-2.1.png`} alt="JH" />
        <span class="footer-copy">© {year} Justine Hornales</span>
      </div>
      <div class="footer-links">
        <a
          class="footer-link"
          href="https://www.linkedin.com/in/justinehornales"
          target="_blank"
          rel="noopener">LinkedIn</a
        >
        <a
          class="footer-link"
          href="https://github.com/justinehornales"
          target="_blank"
          rel="noopener">GitHub</a
        >
        <a class="footer-link" href="mailto:jchornales.dev@gmail.com">Email</a>
      </div>
    </div>
  </div>
</footer>
