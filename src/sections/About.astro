---
const chips = ["Philippines", "Remote-ready", "3+ years", "< 24hr response"];
---

<section id="about">
  <div class="container">
    <div class="section-label reveal">About</div>
    <div class="about-inner">
      <div>
        <h2 class="about-h2 reveal reveal-delay-1">
          Ship fast.<br />Scale clean.<br />Automate the rest.
        </h2>
      </div>
      <div class="about-body reveal reveal-delay-2">
        <p>
          Three-plus years building frontend products — now full-stack, with a focus on how systems
          connect, not just how they look.
        </p>
        <p>
          I help businesses launch faster by pairing tight web development with automation pipelines
          that cut manual work. Whether it's a production website, an n8n workflow, or an AI
          integration, the goal is always the same: less overhead for you.
        </p>
        <p>
          Open to <strong>freelance</strong>, <strong>part-time</strong>, or <strong>full-time</strong>
          work. Remote-friendly. Fast turnaround.
        </p>
        <div class="about-chips">
          {chips.map((c) => <span class="chip">{c}</span>)}
        </div>
      </div>
    </div>
  </div>
</section>
